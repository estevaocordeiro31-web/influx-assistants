NODE_ENV=production
PORT=3003

# Banco de dados (mesmo MySQL da VPS)
DATABASE_URL=mysql://root:SENHA@localhost:3306/influx_tutor
CENTRAL_DATABASE_URL=mysql://root:SENHA@localhost:3306/influx_tutor

# Auth (use o mesmo JWT_SECRET do BRAiN para sessão compartilhada)
JWT_SECRET=mesmo_segredo_do_brain
VITE_APP_ID=influx-tutor

# IA
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_CLOUD_TTS_API_KEY=

# Sponte
SPONTE_LOGIN=
SPONTE_PASSWORD=
SPONTE_API_URL=https://api.sponte.com.br

# Webhook
WEBHOOK_SECRET=

# OAuth Manus (opcional — sem isso só funciona login por senha)
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=

# Storage (deixar vazio — usa armazenamento local)
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=
